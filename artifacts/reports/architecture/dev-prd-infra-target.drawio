        <mxCell id="Wwz4dTcpQKsc2I-YxSQF-1" parent="YGP4cPkty8BirGiZcruj-1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;span style=&quot;font-size: 14px;&quot;&gt;バックエンド&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="-406.75" y="1474" as="geometry" />
        </mxCell>
        <mxCell id="Wwz4dTcpQKsc2I-YxSQF-4" parent="YGP4cPkty8BirGiZcruj-1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;フロントエンド&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="-323.75" y="1322" as="geometry" />
        </mxCell>
        <mxCell id="Wwz4dTcpQKsc2I-YxSQF-5" parent="YGP4cPkty8BirGiZcruj-1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;メイン&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="60" x="-23.75" y="1420" as="geometry" />
        </mxCell>
        <mxCell id="Wwz4dTcpQKsc2I-YxSQF-8" parent="YGP4cPkty8BirGiZcruj-1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;span style=&quot;font-size: 16px;&quot;&gt;開発環境&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="163" x="-493" y="1160" as="geometry" />
        </mxCell>
        <mxCell id="Wwz4dTcpQKsc2I-YxSQF-46" parent="YGP4cPkty8BirGiZcruj-1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;font style=&quot;font-size: 36px;&quot;&gt;電話ドメインフロー&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="350" x="-290" y="1060" as="geometry" />
        </mxCell>
        <mxCell id="Wwz4dTcpQKsc2I-YxSQF-48" parent="YGP4cPkty8BirGiZcruj-1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=11;" value="&lt;div&gt;&lt;font&gt;&lt;b&gt;詳細説明&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;各環境（dev / prd）ごとに分離され、&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;このドメインは複数のサブドメインに分割されます。&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;b&gt;1. 目的&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;各サブドメインは、データや設定が完全に独立した、個別の環境を表します。&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;開発・バックエンド・フロントエンドが完全に分離されており、開発やデバッグ用途に利用されます。&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;エンドユーザーの本番に影響を与えないよう設計されています。&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;本番: 実際のエンドユーザーが利用する環境です。&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;b&gt;2. サブドメイン構成&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・dev.apl.purattocall.com：開発環境&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・apl.purattocall.com：本番環境&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;b&gt;3. SSL証明書構成&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;証明書戦略&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・ワイルドカード証明書 *.apl.purattocall.com を使用して、すべてのサブドメインをカバー&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・証明書: AWS Certificate Manager (ACM)&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・自動更新: ACM による自動更新&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・HTTPSリダイレクト: すべての HTTP トラフィックは HTTPS にリダイレクトされます&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;b&gt;4. データベース構成（環境別RDS）&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・RDSインスタンス: 各環境ごとに個別の RDS インスタンスを使用&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・スキーマ分離:&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;1. appdb → dev.apl.purattocall.com 用&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;2. production app DB → apl.purattocall.com 用&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;ファイルストレージ:&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・開発: denwa-dev-storage（S3バケット）&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・本番: denwa-prd-storage（S3バケット）&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;b&gt;5. APIとサービス通信&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・APIは同一環境内のみで通信されます&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・クロス環境でのAPI呼び出しは禁止&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・各環境に専用エンドポイントが設定されています:&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;1. api-dev.apl.purattocall.com&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;2. api.apl.purattocall.com&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;b&gt;6. デプロイおよびCI/CDフロー&lt;/b&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;デプロイフロー:&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・コードは GitLab リポジトリへ push&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・開発環境（dev.apl.purattocall.com）：自動デプロイ&lt;/font&gt;&lt;/div&gt;&#xa;&lt;div&gt;&lt;font&gt;・本番環境（apl.purattocall.com）：手動承認後にデプロイ実行&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="940" width="430" x="210" y="1085" as="geometry" />
        </mxCell>
        <mxCell id="cJcqPddKa1-fy52OVWlT-0" parent="YGP4cPkty8BirGiZcruj-1" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;fontStyle=1" value="RDS database" vertex="1">
